{
  "version": "0.2.0",
  "configurations": [
    {
      "request": "launch",
      "name": "main",
      "type": "node",
      "program": "${workspaceFolder}/petplay/petplay.ts",
      "cwd": "${workspaceFolder}/petplay",
      "console": "internalConsole",
      "outputCapture": "std",
      "autoAttachChildProcesses": true,
      "env": {},
      "runtimeExecutable": "Deno",
      "runtimeArgs": [
        "run",
        "--inspect-wait",
        "-A",
      ],
    }
  ]
}